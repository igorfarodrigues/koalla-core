# Database
DATABASE_URL=postgresql+asyncpg://koalla:koalla@db:5432/koalla

# OpenAI
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini
OPENAI_FORMATTING_MODEL=gpt-4.1-mini

# Chatwoot
CHATWOOT_URL=https://chatwoot.koalla.ai
CHATWOOT_API_TOKEN=your_chatwoot_token
CHATWOOT_ACCOUNT_ID=1

# Asaas
# Sandbox: https://api-sandbox.asaas.com
# Produção: https://api.asaas.com
ASAAS_URL=https://api-sandbox.asaas.com
# Formato sandbox: $aact_hmlg_...  |  Produção: $aact_prod_...
ASAAS_API_KEY=

# Token de validação dos webhooks do Asaas
# Configurar em: Painel Asaas → Integrações → Webhooks → Token de acesso
ASAAS_WEBHOOK_TOKEN=

# Dias de trial gratuito (15 = promo atual)
TRIAL_DAYS=15

# Horas de carência após pagamento atrasado antes de suspender o acesso
GRACE_HOURS=48

# Valores dos planos (R$)
PLAN_STARTER_VALUE=29.90
PLAN_PRO_VALUE=79.90
PLAN_BUSINESS_VALUE=99.90

# Agent
# Tempo de espera do debounce (agrupa mensagens enviadas em sequência rápida)
MESSAGE_QUEUE_WAIT_SECONDS=2.0
AGENT_MAX_ITERATIONS=10
MEMORY_WINDOW_LENGTH=100

# Billing defaults
CHARGE_VALUE=500.0
CHARGE_DURATION_MINUTES=30

# Alert conversation ID (for human escalation)
ALERT_CONVERSATION_ID=

# Número do WhatsApp Business do Koalla (conectado ao Chatwoot)
# Usado no link de onboarding após o cadastro na landing page
# Formato: código do país + DDD + número, sem espaços ou símbolos
# Exemplo: 5511999999999
KOALLA_WA_NUMBER=

# ============================================================================
# Segurança do Webhook
# ============================================================================
#
# Deve ser configurado também no Chatwoot.
#
# O Chatwoot deverá enviar:
#
# X-Koalla-Secret: <valor_definido_aqui>
#
# O backend rejeitará qualquer requisição cujo header
# não corresponda exatamente ao valor abaixo.
#
# Exemplo:
# CHATWOOT_WEBHOOK_SECRET=minha_chave_super_secreta
#
CHATWOOT_WEBHOOK_SECRET=